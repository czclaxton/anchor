---
import { getCollection } from 'astro:content'
import type { CollectionEntry } from 'astro:content'
import { formatSlug } from '../lib/format'

const lessons: CollectionEntry<'lessons'>[] = await getCollection('lessons')
const subjects = [...new Set(lessons.map((l) => l.data.subject))]
---

<header class="border-b border-gray-200 bg-white px-6 py-4">
  <nav class="flex items-center gap-8">
    <a href="/" class="text-xl font-bold text-blue-600 hover:text-blue-800">
      Anchor
    </a>
    <ul class="flex items-center gap-6">
      {
        subjects.map((subject) => (
          <li>
            <a
              href={`/${subject}`}
              class="text-sm font-medium text-gray-600 hover:text-blue-600"
            >
              {formatSlug(subject)}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>
