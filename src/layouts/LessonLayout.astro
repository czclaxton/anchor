---
import { getCollection } from 'astro:content'
import type { CollectionEntry } from 'astro:content'
import BaseLayout from './BaseLayout.astro'
import Breadcrumb from '../components/Breadcrumb.astro'

interface Props {
  entry: CollectionEntry<'lessons'>
}

const { entry } = Astro.props
const { title, subject, unit } = entry.data

const allLessons: CollectionEntry<'lessons'>[] = await getCollection('lessons')
allLessons.sort((a, b) => a.data.order - b.data.order)

const currentIndex = allLessons.findIndex((l) => l.slug === entry.slug)
const prev = currentIndex > 0 ? allLessons[currentIndex - 1] : null
const next =
  currentIndex < allLessons.length - 1 ? allLessons[currentIndex + 1] : null

function lessonHref(lesson: CollectionEntry<'lessons'>) {
  return `/${lesson.slug}`
}

function formatLabel(slug: string) {
  return slug.replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase())
}

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: formatLabel(subject), href: `/${subject}` },
  ...(unit ? [{ label: formatLabel(unit), href: `/${subject}` }] : []),
  { label: title },
]
---

<BaseLayout title={title}>
  <div class="mx-auto max-w-3xl px-6 py-12">
    <Breadcrumb items={breadcrumbs} />

    <header class="mb-10">
      <p class="text-sm font-medium uppercase tracking-wide text-blue-600">
        {formatLabel(subject)}
      </p>
      <h1 class="mt-1 text-4xl font-bold">{title}</h1>
    </header>

    <section class="mb-8">
      <h2 class="mb-2 text-xl font-semibold">Hook</h2>
      <slot name="hook"
        ><p class="italic text-gray-500">[Hook placeholder]</p></slot
      >
    </section>

    <section class="mb-8">
      <h2 class="mb-2 text-xl font-semibold">Analogy</h2>
      <slot name="analogy"
        ><p class="italic text-gray-500">[Analogy placeholder]</p></slot
      >
    </section>

    <div class="mb-8">
      <slot name="image" />
    </div>

    <section class="mb-8">
      <h2 class="mb-2 text-xl font-semibold">Explanation</h2>
      <slot name="explanation"
        ><p class="italic text-gray-500">[Explanation placeholder]</p></slot
      >
    </section>

    <div class="mb-8">
      <slot name="editor" />
    </div>

    <div class="mb-8">
      <slot name="interactive" />
    </div>

    <section class="mb-8">
      <h2 class="mb-2 text-xl font-semibold">Summary</h2>
      <slot name="summary"
        ><p class="italic text-gray-500">[Summary placeholder]</p></slot
      >
    </section>

    <div class="mb-8">
      <slot name="anchored-button">
        <button
          type="button"
          class="rounded-lg bg-blue-600 px-6 py-3 font-semibold text-white"
        >
          Anchored!
        </button>
      </slot>
    </div>

    <nav
      class="mt-12 flex items-center justify-between border-t border-gray-200 pt-6 text-sm"
    >
      {
        prev ? (
          <a
            href={lessonHref(prev)}
            class="flex items-center gap-1 text-blue-600 hover:text-blue-800"
          >
            ← {prev.data.title}
          </a>
        ) : (
          <span />
        )
      }
      {
        next ? (
          <a
            href={lessonHref(next)}
            class="flex items-center gap-1 text-blue-600 hover:text-blue-800"
          >
            {next.data.title} →
          </a>
        ) : (
          <span />
        )
      }
    </nav>
  </div>
</BaseLayout>
